# Frontend
VITE_APP_NAME=OpenClaw Unified Control Plane

# Database
DATABASE_URL=postgresql://app_user:password@your-pooled-host.neon.tech/neondb?sslmode=require
MIGRATION_DATABASE_URL=postgresql://app_user:password@your-direct-host.neon.tech/neondb?sslmode=require

# Session/auth
SESSION_SECRET=replace-with-a-32-byte-random-string
APP_BASE_URL=http://localhost:8888

# Worker authentication
WORKER_SHARED_SECRET=replace-with-a-long-random-string
WORKER_LEASE_SECONDS=45

# Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_USAGE_PRICE_ID=price_...
STRIPE_METER_EVENT_NAME=bot_usage_units
STRIPE_SUCCESS_URL=http://localhost:8888/app?billing=success
STRIPE_CANCEL_URL=http://localhost:8888/app?billing=cancelled

# Pricing knobs
BILLING_LLM_MARKUP_FACTOR=1.3
BILLING_DESKTOP_MINUTE_RATE=0.10
BILLING_BROWSER_MINUTE_RATE=0.05
BILLING_SCREENSHOT_RATE=0.01
BILLING_RETRY_PENALTY=0.02

# Worker runtime
SITE_URL=http://localhost:8888
BOT_ID=replace-with-bot-id
WORKER_ID=windows-worker-1
MACHINE_NAME=windows-laptop
POLL_INTERVAL_MS=5000
EXECUTOR_MODE=command
EXECUTOR_TIMEOUT_MS=1200000

# Local runtime bridge
LOCAL_RUNTIME_URL=http://127.0.0.1:3002
LOCAL_RUNTIME_SECRET=replace-with-a-local-secret
OPENCLAW_COMMAND=node worker/runtime-bridge-executor.mjs
OPENCLAW_WEBHOOK_URL=http://127.0.0.1:3002/v1/tasks/execute

# Local browser API
BROWSER_API_URL=http://127.0.0.1:3001
BROWSER_API_SECRET=replace-with-browser-secret
OPENCLAW_BASE_URL=http://127.0.0.1:18789
RUNTIME_ROOT=/home/zach/oc-runtime
RUNTIME_HOST=127.0.0.1
RUNTIME_PORT=3002
BROWSER_API_HOST=127.0.0.1
BROWSER_API_PORT=3001

# Legacy runner variables (only if you use legacy/runner)
COCKPIT_BASE_URL=http://localhost:8888
ADMIN_TOKEN=replace-with-legacy-admin-token
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
